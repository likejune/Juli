{
  "name": "julia-bunyakova-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Official artist website & gallery management system for Julia Bunyakova",
  "scripts": {
    "predev": "node scripts/init-db.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/init-db.mjs",
    "build": "next build",
    "build:vercel": "node scripts/use-postgres.mjs && prisma generate && prisma db push --skip-generate --accept-data-loss && node prisma/seed.mjs && next build",
    "prestart": "node scripts/init-db.mjs",
    "start": "next start",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "lint": "next lint"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "chart.js": "4.4.7",
    "jose": "5.9.6",
    "next": "14.2.21",
    "react": "18.3.1",
    "react-chartjs-2": "5.2.0",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.17.10",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
