# ============================================================
# Julia Bunyakova CMS — environment variables
# Copy this file to .env and adjust the values.
# ============================================================

# --- Database -------------------------------------------------
# Local development / Open Server Panel (SQLite, zero config):
DATABASE_URL="file:./dev.db"

# Production on Vercel (PostgreSQL — Vercel Postgres / Neon / Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/julia_cms?sslmode=require"

# --- Security -------------------------------------------------
# Secret used to sign admin session tokens (JWT).
# Generate your own: `openssl rand -hex 32`
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# --- Site -----------------------------------------------------
# Public base URL (used for Open Graph / sitemap)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
